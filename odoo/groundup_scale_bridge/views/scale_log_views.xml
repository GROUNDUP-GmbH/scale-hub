<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="groundup_scale_log_list" model="ir.ui.view">
        <field name="name">groundup.scale.log.list</field>
        <field name="model">groundup.scale.log</field>
        <field name="arch" type="xml">
            <list string="Scale Audit Log" create="0" edit="0" delete="0"
                  decoration-danger="event_type in ('plu_mismatch','sale_parse_error','plu_select_failed')"
                  decoration-success="event_type == 'sale_completed'"
                  decoration-info="event_type == 'plu_uploaded'">
                <field name="create_date" string="Timestamp"/>
                <field name="device_id"/>
                <field name="event_type"/>
                <field name="entry_hash"/>
                <field name="prev_hash" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="groundup_scale_log_form" model="ir.ui.view">
        <field name="name">groundup.scale.log.form</field>
        <field name="model">groundup.scale.log</field>
        <field name="arch" type="xml">
            <form string="Scale Log Entry" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="event_type"/>
                            <field name="device_id"/>
                            <field name="hub_timestamp"/>
                        </group>
                        <group>
                            <field name="entry_hash"/>
                            <field name="prev_hash"/>
                        </group>
                    </group>
                    <group string="Payload">
                        <field name="payload_json" widget="ace" options="{'mode': 'json'}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="groundup_scale_log_search" model="ir.ui.view">
        <field name="name">groundup.scale.log.search</field>
        <field name="model">groundup.scale.log</field>
        <field name="arch" type="xml">
            <search string="Scale Log">
                <field name="event_type"/>
                <field name="device_id"/>
                <field name="entry_hash"/>
                <separator/>
                <filter name="sales" string="Sales" domain="[('event_type','=','sale_completed')]"/>
                <filter name="errors" string="Errors" domain="[('event_type','in',['plu_mismatch','sale_parse_error','plu_select_failed'])]"/>
                <filter name="plu_changes" string="PLU Changes" domain="[('event_type','in',['plu_uploaded','plu_selected'])]"/>
                <group expand="0" string="Group By">
                    <filter name="by_device" string="Device" context="{'group_by': 'device_id'}"/>
                    <filter name="by_event" string="Event Type" context="{'group_by': 'event_type'}"/>
                    <filter name="by_day" string="Day" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="groundup_scale_log_action" model="ir.actions.act_window">
        <field name="name">Scale Audit Log</field>
        <field name="res_model">groundup.scale.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_sales': 1}</field>
    </record>

</odoo>
